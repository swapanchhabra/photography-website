---
---

<form
  action="https://api.web3forms.com/submit"
  method="POST"
  id="contact-form"
  class="space-y-6"
>
  <!-- Web3Forms access key — get yours free at https://web3forms.com -->
  <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
  <input type="hidden" name="subject" value="Neue Hochzeitsanfrage über die Website" />
  <input type="hidden" name="from_name" value="Pose and Say Cheese Photography" />
  <input type="hidden" name="redirect" value="https://pose-and-say-cheese.de/kontakt/erfolg" />
  <!-- Honeypot spam protection -->
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

  <div>
    <label for="name" class="block text-sm font-medium text-neutral-700 mb-2">Name *</label>
    <input
      type="text"
      id="name"
      name="name"
      required
      class="w-full px-4 py-3.5 border border-neutral-300 bg-white text-neutral-900 text-sm transition-all duration-300 focus:outline-none focus:border-neutral-900 focus:ring-1 focus:ring-neutral-900"
      placeholder="Ihr vollständiger Name"
    />
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="email" class="block text-sm font-medium text-neutral-700 mb-2">E-Mail *</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full px-4 py-3.5 border border-neutral-300 bg-white text-neutral-900 text-sm transition-all duration-300 focus:outline-none focus:border-neutral-900 focus:ring-1 focus:ring-neutral-900"
        placeholder="ihre@email.de"
      />
    </div>
    <div>
      <label for="phone" class="block text-sm font-medium text-neutral-700 mb-2">Telefon</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        class="w-full px-4 py-3.5 border border-neutral-300 bg-white text-neutral-900 text-sm transition-all duration-300 focus:outline-none focus:border-neutral-900 focus:ring-1 focus:ring-neutral-900"
        placeholder="+49 XXX XXXXXXX"
      />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="date" class="block text-sm font-medium text-neutral-700 mb-2">Hochzeitsdatum</label>
      <input
        type="date"
        id="date"
        name="Hochzeitsdatum"
        class="w-full px-4 py-3.5 border border-neutral-300 bg-white text-neutral-900 text-sm transition-all duration-300 focus:outline-none focus:border-neutral-900 focus:ring-1 focus:ring-neutral-900"
      />
    </div>
    <div>
      <label for="location" class="block text-sm font-medium text-neutral-700 mb-2">Location</label>
      <input
        type="text"
        id="location"
        name="Location"
        class="w-full px-4 py-3.5 border border-neutral-300 bg-white text-neutral-900 text-sm transition-all duration-300 focus:outline-none focus:border-neutral-900 focus:ring-1 focus:ring-neutral-900"
        placeholder="Name der Location"
      />
    </div>
  </div>

  <div>
    <label for="message" class="block text-sm font-medium text-neutral-700 mb-2">Nachricht *</label>
    <textarea
      id="message"
      name="Nachricht"
      required
      rows="5"
      class="w-full px-4 py-3.5 border border-neutral-300 bg-white text-neutral-900 text-sm transition-all duration-300 focus:outline-none focus:border-neutral-900 focus:ring-1 focus:ring-neutral-900 resize-none"
      placeholder="Erzählen Sie mir von Ihrer Hochzeit..."
    ></textarea>
  </div>

  <button
    type="submit"
    class="w-full py-4 bg-neutral-900 text-white text-sm font-semibold uppercase tracking-widest hover:bg-neutral-800 transition-all duration-300"
  >
    Nachricht senden
  </button>
</form>
