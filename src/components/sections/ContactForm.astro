---
const inputClass = 'w-full px-4 py-3.5 border border-neutral-300 bg-white text-neutral-900 text-sm transition-all duration-300 focus:outline-none focus:border-neutral-900 focus:ring-1 focus:ring-neutral-900';
---

<form
  action="https://api.web3forms.com/submit"
  method="POST"
  id="contact-form"
  class="space-y-6"
  novalidate
>
  <input type="hidden" name="access_key" value="f57e65cd-ea67-4738-8c77-3fd9240b0055" />
  <input type="hidden" name="subject" value="Neue Hochzeitsanfrage über die Website" />
  <input type="hidden" name="from_name" value="Pose and Say Cheese Photography" />
  <input type="hidden" name="redirect" value="/kontakt/erfolg" />
  <!-- Honeypot spam protection -->
  <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

  <div>
    <label for="name" class="block text-sm font-medium text-neutral-700 mb-2">Name <span class="text-red-500">*</span></label>
    <input
      type="text"
      id="name"
      name="name"
      required
      autocomplete="name"
      class={inputClass}
      placeholder="Euer Name"
    />
    <p class="mt-1 text-xs text-red-500 hidden" data-error="name">Bitte gebt euren Namen ein.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="email" class="block text-sm font-medium text-neutral-700 mb-2">E-Mail <span class="text-red-500">*</span></label>
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="email"
        inputmode="email"
        class={inputClass}
        placeholder="ihre@email.de"
      />
      <p class="mt-1 text-xs text-red-500 hidden" data-error="email">Bitte gebt eine gültige E-Mail-Adresse ein.</p>
    </div>
    <div>
      <label for="phone" class="block text-sm font-medium text-neutral-700 mb-2">Telefon <span class="text-neutral-400 font-normal">(optional)</span></label>
      <input
        type="tel"
        id="phone"
        name="phone"
        autocomplete="tel"
        inputmode="tel"
        class={inputClass}
        placeholder="+49 XXX XXXXXXX"
      />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="date" class="block text-sm font-medium text-neutral-700 mb-2">Hochzeitsdatum <span class="text-neutral-400 font-normal">(optional)</span></label>
      <input
        type="date"
        id="date"
        name="hochzeitsdatum"
        class={inputClass}
      />
    </div>
    <div>
      <label for="location" class="block text-sm font-medium text-neutral-700 mb-2">Location <span class="text-neutral-400 font-normal">(optional)</span></label>
      <input
        type="text"
        id="location"
        name="location"
        class={inputClass}
        placeholder="Name der Location"
      />
    </div>
  </div>

  <div>
    <label for="message" class="block text-sm font-medium text-neutral-700 mb-2">Nachricht <span class="text-red-500">*</span></label>
    <textarea
      id="message"
      name="nachricht"
      required
      rows="5"
      class={`${inputClass} resize-none`}
      placeholder="Erzählt mir von eurer Hochzeit..."
    ></textarea>
    <p class="mt-1 text-xs text-red-500 hidden" data-error="message">Bitte schreibt eine Nachricht.</p>
  </div>

  <button
    type="submit"
    id="submit-btn"
    class="w-full py-4 bg-neutral-900 text-white text-sm font-semibold uppercase tracking-widest hover:bg-neutral-800 transition-all duration-300 min-h-[48px] disabled:opacity-50 disabled:cursor-not-allowed"
  >
    <span id="btn-text">Nachricht senden</span>
    <span id="btn-loading" class="hidden">Wird gesendet...</span>
  </button>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text')!;
  const btnLoading = document.getElementById('btn-loading')!;

  // Show/hide error messages on blur
  form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[required]').forEach((field) => {
    field.addEventListener('blur', () => validateField(field));
    field.addEventListener('input', () => {
      if (field.classList.contains('border-red-500')) {
        validateField(field);
      }
    });
  });

  function validateField(field: HTMLInputElement | HTMLTextAreaElement) {
    const errorEl = form.querySelector(`[data-error="${field.id}"]`);
    if (!field.validity.valid) {
      field.classList.add('border-red-500');
      field.classList.remove('border-neutral-300');
      errorEl?.classList.remove('hidden');
    } else {
      field.classList.remove('border-red-500');
      field.classList.add('border-neutral-300');
      errorEl?.classList.add('hidden');
    }
  }

  form.addEventListener('submit', (e) => {
    // Validate all required fields
    let hasErrors = false;
    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[required]').forEach((field) => {
      validateField(field);
      if (!field.validity.valid) hasErrors = true;
    });

    if (hasErrors) {
      e.preventDefault();
      return;
    }

    // Show loading state
    btn.disabled = true;
    btnText.classList.add('hidden');
    btnLoading.classList.remove('hidden');
  });
</script>
