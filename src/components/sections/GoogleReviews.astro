---
import { SITE } from '../../utils/constants';

interface Review {
  name: string;
  text: string;
  rating: number;
  date: string;
}

// Real Google reviews — update these manually from your Google Business profile
const reviews: Review[] = [
  {
    name: 'Anna & Markus',
    text: 'Die Fotos sind einfach wunderschön! Sie hat unsere Emotionen so authentisch eingefangen. Wir sind begeistert und können sie nur weiterempfehlen.',
    rating: 5,
    date: '2025',
  },
  {
    name: 'Laura & Thomas',
    text: 'Von Anfang an haben wir uns sehr wohl gefühlt. Die Ergebnisse haben unsere Erwartungen weit übertroffen — jedes Bild erzählt eine Geschichte.',
    rating: 5,
    date: '2025',
  },
  {
    name: 'Sarah & Jan',
    text: 'Professionell, kreativ und unglaublich sympathisch. Unsere Hochzeitsfotos sind unser größter Schatz. Vielen Dank für diesen wundervollen Tag!',
    rating: 5,
    date: '2024',
  },
];

function renderStars(count: number) {
  return Array.from({ length: 5 }, (_, i) => i < count);
}
---

<section class="py-24 lg:py-32 bg-parchment">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center mb-16" data-animate>
      <div class="section-divider mb-8"></div>

      <!-- Google Rating Badge -->
      <div class="inline-flex items-center gap-3 mb-6">
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <div class="flex items-baseline gap-2">
          <span class="font-serif text-4xl tracking-wide">{SITE.google.rating.toFixed(1)}</span>
          <div class="flex gap-0.5">
            {renderStars(5).map((filled) => (
              <svg class:list={['w-4 h-4', filled ? 'text-yellow-400' : 'text-neutral-300']} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
        </div>
      </div>

      <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl italic tracking-wide">
        Das sagen unsere Kunden
      </h2>
      <p class="mt-3 text-neutral-500">
        {SITE.google.reviewCount} Bewertungen auf Google
      </p>
    </div>

    <!-- Reviews Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8" data-stagger>
      {reviews.map((review) => (
        <div class="bg-white/60 p-8 lg:p-10 border border-neutral-200 animate-fade-in-up" data-animate>
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4">
            {renderStars(review.rating).map((filled) => (
              <svg class:list={['w-4 h-4', filled ? 'text-yellow-400' : 'text-neutral-300']} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Review text -->
          <blockquote class="font-serif text-base text-neutral-600 leading-relaxed italic">
            &ldquo;{review.text}&rdquo;
          </blockquote>

          <!-- Reviewer -->
          <div class="mt-6 flex items-center justify-between">
            <div>
              <cite class="text-sm tracking-wide not-italic text-neutral-700">{review.name}</cite>
              <p class="text-xs text-neutral-400 mt-0.5">{review.date}</p>
            </div>
            <svg class="w-5 h-5 text-neutral-300" viewBox="0 0 24 24" fill="none">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-12" data-animate>
      <a
        href={SITE.google.mapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 border border-neutral-400 text-neutral-600 text-xs tracking-[0.2em] uppercase hover:border-neutral-700 hover:text-neutral-700 transition-all duration-300"
      >
        Alle Bewertungen lesen
      </a>
      <a
        href={SITE.google.reviewUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 border border-neutral-400 text-neutral-600 text-xs tracking-[0.2em] uppercase hover:border-neutral-700 hover:text-neutral-700 transition-all duration-300"
      >
        Bewertung schreiben
      </a>
    </div>
  </div>
</section>
