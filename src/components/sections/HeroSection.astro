---
interface Props {
  title: string;
  subtitle?: string;
  image: string;
  cta?: { label: string; href: string };
  fullHeight?: boolean;
  overlay?: boolean;
}

const {
  title,
  subtitle,
  image,
  cta,
  fullHeight = false,
  overlay = true,
} = Astro.props;
---

<section
  data-hero
  class:list={[
    'relative flex items-center justify-center overflow-hidden',
    fullHeight ? 'min-h-screen' : 'min-h-[60vh] lg:min-h-[70vh]',
  ]}
  aria-label={title}
>
  <!-- Background Image -->
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style={`background-image: url('${image}')`}
    role="img"
    aria-label={`Hintergrundbild: ${title}`}
  >
    {overlay && <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/10 to-black/40" aria-hidden="true"></div>}
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl text-white tracking-wide italic animate-fade-in-up" style="font-weight: 300; line-height: 1.1;">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-8 text-sm sm:text-base lg:text-lg text-white/80 tracking-[0.2em] uppercase animate-fade-in-up animate-delay-200" style="font-weight: 400;">
        {subtitle}
      </p>
    )}
    {cta && (
      <div class="mt-12 animate-fade-in-up animate-delay-300">
        <a
          href={cta.href}
          class="inline-block px-10 py-4 border border-white/60 text-white text-xs tracking-[0.25em] uppercase hover:bg-white/10 transition-all duration-500 min-h-[44px]"
        >
          {cta.label}
        </a>
      </div>
    )}
  </div>

  <!-- Scroll indicator -->
  {fullHeight && (
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce" aria-hidden="true">
      <svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  )}
</section>
