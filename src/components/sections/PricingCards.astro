---
import type { Package } from '../../data/packages';
import { PACKAGES } from '../../data/packages';

interface Props {
  packages?: Package[];
}

const { packages = PACKAGES } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
  {packages.map((pkg) => (
    <div
      class:list={[
        'relative flex flex-col p-8 lg:p-10 transition-all duration-500 hover:-translate-y-1',
        pkg.highlighted
          ? 'bg-neutral-800 text-white border border-neutral-700 shadow-xl scale-[1.02] lg:scale-105'
          : 'bg-parchment border border-neutral-200 hover:shadow-lg',
      ]}
      data-animate
    >
      {pkg.highlighted && (
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-accent text-white text-xs tracking-[0.15em] uppercase">
          Beliebt
        </span>
      )}
      <h3 class="font-serif text-2xl italic tracking-wide">{pkg.name}</h3>
      <p class="mt-2 font-serif text-3xl tracking-wide">
        {pkg.price}
      </p>
      <p class:list={[
        'mt-3 text-sm',
        pkg.highlighted ? 'text-white/60' : 'text-neutral-500',
      ]}>
        {pkg.description}
      </p>
      <ul class="mt-8 space-y-3 flex-1">
        {pkg.features.map((feature) => (
          <li class="flex items-start gap-3 text-sm">
            <svg class:list={['w-5 h-5 flex-shrink-0 mt-0.5', pkg.highlighted ? 'text-accent' : 'text-accent']} fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" />
            </svg>
            <span>{feature}</span>
          </li>
        ))}
      </ul>
      <a
        href="/kontakt"
        class:list={[
          'mt-8 block text-center px-6 py-4 text-xs tracking-[0.2em] uppercase transition-all duration-300',
          pkg.highlighted
            ? 'border border-white/40 text-white hover:bg-white/10'
            : 'border border-neutral-400 text-neutral-600 hover:border-neutral-700 hover:text-neutral-700',
        ]}
      >
        Jetzt anfragen
      </a>
    </div>
  ))}
</div>
