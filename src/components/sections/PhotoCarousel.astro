---
import type { GalleryImage } from '../../data/gallery';

interface Props {
  images: GalleryImage[];
  interval?: number;
  hero?: boolean;
  title?: string;
  subtitle?: string;
}

const { images, interval = 4000, hero = false, title, subtitle } = Astro.props;
---

<section
  class:list={[
    'photo-carousel relative w-full overflow-hidden',
    hero ? 'min-h-[60vh] lg:min-h-[70vh]' : '',
  ]}
  data-interval={interval}
  data-hero={hero ? '' : undefined}
  role="region"
  aria-label={title || 'Bildergalerie'}
  aria-roledescription="carousel"
>
  <!-- Slides -->
  <div class:list={[
    'relative bg-neutral-200',
    hero ? 'h-full absolute inset-0' : 'aspect-[3/2] sm:aspect-[16/9] lg:aspect-[21/9]',
  ]}>
    {images.map((img, i) => (
      <div
        class:list={[
          'carousel-slide absolute inset-0 transition-opacity duration-1000',
          i === 0 ? 'opacity-100' : 'opacity-0',
        ]}
        role="group"
        aria-roledescription="slide"
        aria-label={`Bild ${i + 1} von ${images.length}`}
        aria-hidden={i !== 0 ? 'true' : undefined}
      >
        <img
          src={img.src}
          alt={img.alt}
          width={img.width}
          height={img.height}
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
          class="w-full h-full object-cover"
        />
      </div>
    ))}
    {hero && <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/10 to-black/40" aria-hidden="true"></div>}
  </div>

  <!-- Hero text overlay -->
  {hero && title && (
    <div class="absolute inset-0 z-10 flex items-center justify-center">
      <div class="text-center px-6 max-w-4xl mx-auto">
        <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-light leading-tight text-white tracking-wide italic animate-fade-in-up">
          {title}
        </h1>
        {subtitle && (
          <p class="mt-8 text-sm sm:text-base lg:text-lg text-white/80 tracking-[0.2em] uppercase animate-fade-in-up animate-delay-200">
            {subtitle}
          </p>
        )}
      </div>
    </div>
  )}

  <!-- Navigation dots -->
  <div class:list={[
    'absolute left-1/2 -translate-x-1/2 flex gap-2.5 z-20',
    hero ? 'bottom-8' : 'bottom-4',
  ]} role="tablist" aria-label="Bilder auswählen">
    {images.map((_, i) => (
      <button
        type="button"
        class:list={[
          'carousel-dot w-2 h-2 rounded-full transition-all duration-300',
          i === 0 ? 'bg-white scale-125' : 'bg-white/50 hover:bg-white/80',
        ]}
        role="tab"
        aria-selected={i === 0 ? 'true' : 'false'}
        aria-label={`Bild ${i + 1}`}
        data-index={i}
      />
    ))}
  </div>

  <!-- Prev/Next buttons -->
  <button
    type="button"
    class="carousel-prev absolute left-3 top-1/2 -translate-y-1/2 p-2 text-white/60 hover:text-white transition-colors z-20"
    aria-label="Vorheriges Bild"
  >
    <svg class="w-6 h-6 sm:w-8 sm:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  <button
    type="button"
    class="carousel-next absolute right-3 top-1/2 -translate-y-1/2 p-2 text-white/60 hover:text-white transition-colors z-20"
    aria-label="Nächstes Bild"
  >
    <svg class="w-6 h-6 sm:w-8 sm:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>
</section>

<script>
  const SWIPE_THRESHOLD_PX = 50;
  let cleanups: (() => void)[] = [];

  function initCarousels() {
    cleanups.forEach((fn) => fn());
    cleanups = [];

    document.querySelectorAll<HTMLElement>('.photo-carousel').forEach((carousel) => {
      if (carousel.dataset.initialized) return;
      carousel.dataset.initialized = 'true';

      const slides = carousel.querySelectorAll<HTMLElement>('.carousel-slide');
      const dots = carousel.querySelectorAll<HTMLElement>('.carousel-dot');
      const interval = Number(carousel.dataset.interval) || 4000;
      const ac = new AbortController();
      const { signal } = ac;
      let current = 0;
      let timer: ReturnType<typeof setInterval>;

      function goTo(index: number) {
        const next = (index + slides.length) % slides.length;
        if (next === current) return;

        slides[current].classList.replace('opacity-100', 'opacity-0');
        slides[current].setAttribute('aria-hidden', 'true');
        dots[current].classList.replace('bg-white', 'bg-white/50');
        dots[current].classList.remove('scale-125');
        dots[current].setAttribute('aria-selected', 'false');

        current = next;

        slides[current].classList.replace('opacity-0', 'opacity-100');
        slides[current].removeAttribute('aria-hidden');
        dots[current].classList.replace('bg-white/50', 'bg-white');
        dots[current].classList.add('scale-125');
        dots[current].setAttribute('aria-selected', 'true');
      }

      function startAutoplay() {
        timer = setInterval(() => goTo(current + 1), interval);
      }

      function resetAutoplay() {
        clearInterval(timer);
        startAutoplay();
      }

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          goTo(Number(dot.dataset.index));
          resetAutoplay();
        }, { signal });
      });

      carousel.querySelector('.carousel-prev')?.addEventListener('click', () => {
        goTo(current - 1);
        resetAutoplay();
      }, { signal });

      carousel.querySelector('.carousel-next')?.addEventListener('click', () => {
        goTo(current + 1);
        resetAutoplay();
      }, { signal });

      carousel.addEventListener('mouseenter', () => clearInterval(timer), { signal });
      carousel.addEventListener('mouseleave', startAutoplay, { signal });

      let touchStartX = 0;
      carousel.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
        clearInterval(timer);
      }, { passive: true, signal });

      carousel.addEventListener('touchend', (e) => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > SWIPE_THRESHOLD_PX) {
          goTo(diff > 0 ? current + 1 : current - 1);
        }
        startAutoplay();
      }, { passive: true, signal });

      startAutoplay();

      cleanups.push(() => {
        clearInterval(timer);
        ac.abort();
        delete carousel.dataset.initialized;
      });
    });
  }

  initCarousels();
  document.addEventListener('astro:after-swap', initCarousels);
</script>
