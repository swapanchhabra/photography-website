---
import { NAV_ITEMS, SITE } from '../../utils/constants';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header
  id="header"
  class="site-header fixed top-0 left-0 right-0 z-[55] transition-all duration-500"
>
  <nav class="mx-auto max-w-7xl px-6 py-5 flex items-center justify-between" aria-label="Hauptnavigation">
    <!-- Logo -->
    <a href="/" class="header-logo font-serif text-xl tracking-[0.15em] uppercase transition-colors duration-300" id="logo-link">
      {SITE.name}
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden lg:flex items-center gap-8" role="list">
      {NAV_ITEMS.map((item) => (
        <li>
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'header-nav-link relative font-serif text-sm italic tracking-wide transition-colors duration-300',
              'after:absolute after:bottom-[-4px] after:left-0 after:h-[1px] after:bg-current after:transition-all after:duration-300',
              isActive(item.href)
                ? 'after:w-full'
                : 'after:w-0 hover:after:w-full',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden flex flex-col gap-[5px] p-3 z-[60] relative"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="header-bar block w-7 h-[1px] transition-all duration-300 origin-center pointer-events-none" id="bar1"></span>
      <span class="header-bar block w-7 h-[1px] transition-all duration-300 pointer-events-none" id="bar2"></span>
    </button>
  </nav>
</header>

<!-- SVG noise filter for parchment texture (hidden, only defines filter) -->
<svg class="hidden" aria-hidden="true">
  <filter id="paper-noise">
    <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="5" stitchTiles="stitch" />
    <feColorMatrix type="saturate" values="0" />
  </filter>
</svg>

<!-- Mobile Menu Overlay (outside header to avoid iOS nested fixed positioning issues) -->
<div
  id="mobile-menu"
  role="dialog"
  aria-label="Navigation"
  class="mobile-menu-overlay fixed inset-0 z-[56] flex flex-col items-center justify-center gap-6 opacity-0 pointer-events-none transition-opacity duration-500 lg:hidden pt-[env(safe-area-inset-top)]"
>
  <!-- Close button -->
  <button
    id="mobile-menu-close"
    class="absolute top-8 right-6 p-3 text-neutral-400 hover:text-neutral-700 transition-colors z-[60]"
    aria-label="Menü schließen"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  <nav aria-label="Mobile Navigation">
    <ul class="flex flex-col items-center gap-7" role="list">
      {NAV_ITEMS.map((item) => (
        <li>
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'font-serif text-2xl italic tracking-wider transition-colors duration-300',
              isActive(item.href) ? 'text-neutral-800' : 'text-neutral-400 hover:text-neutral-700',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</div>

<style is:global>
  /* Mobile menu: parchment texture background */
  .mobile-menu-overlay {
    background-color: #f0ebe1;
    position: relative;
  }
  .mobile-menu-overlay::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.4;
    background-image:
      radial-gradient(ellipse at 20% 50%, rgba(200, 185, 160, 0.3) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(210, 195, 170, 0.25) 0%, transparent 40%),
      radial-gradient(ellipse at 50% 80%, rgba(190, 175, 150, 0.2) 0%, transparent 45%);
    pointer-events: none;
    z-index: 0;
  }
  .mobile-menu-overlay::after {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.5;
    filter: url(#paper-noise);
    background-color: rgba(180, 165, 140, 0.15);
    pointer-events: none;
    z-index: 0;
  }
  .mobile-menu-overlay > * {
    position: relative;
    z-index: 1;
  }

  /* Default state: transparent header with white text (over hero image) */
  .site-header .header-logo {
    color: #ffffff;
  }
  .site-header .header-nav-link {
    color: rgba(255, 255, 255, 0.8);
  }
  .site-header .header-nav-link:hover {
    color: #ffffff;
  }
  .site-header .header-bar {
    background-color: #ffffff;
  }

  /* Scrolled state: cream background with muted text */
  .site-header.scrolled {
    background-color: rgba(245, 240, 232, 0.95);
    backdrop-filter: blur(12px);
  }
  .site-header.scrolled .header-logo {
    color: #564f4a;
  }
  .site-header.scrolled .header-nav-link {
    color: #8a8380;
  }
  .site-header.scrolled .header-nav-link:hover {
    color: #564f4a;
  }
  .site-header.scrolled .header-bar {
    background-color: #564f4a;
  }

  /* When mobile menu is open, reset header to transparent */
  .site-header.menu-open {
    background-color: transparent !important;
    backdrop-filter: none !important;
    box-shadow: none !important;
  }
  .site-header.menu-open .header-logo {
    color: #564f4a !important;
  }
  .site-header.menu-open .header-bar {
    background-color: #564f4a !important;
  }
</style>

<script>
  let header: HTMLElement;
  let btn: HTMLElement;
  let menu: HTMLElement;
  let closeBtn: HTMLElement;
  let isOpen = false;
  let hasHero = false;

  function toggleMenu(open: boolean) {
    isOpen = open;
    btn.setAttribute('aria-expanded', String(isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Menü schließen' : 'Menü öffnen');
    if (isOpen) {
      menu.classList.remove('opacity-0', 'pointer-events-none');
      menu.classList.add('opacity-100', 'pointer-events-auto');
      header.classList.add('menu-open');
      btn.classList.add('invisible');
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    } else {
      menu.classList.add('opacity-0', 'pointer-events-none');
      menu.classList.remove('opacity-100', 'pointer-events-auto');
      header.classList.remove('menu-open');
      btn.classList.remove('invisible');
      document.body.style.overflow = '';
    }
  }

  function updateHeader() {
    if (!hasHero || window.scrollY > 50) {
      header.classList.add('scrolled');
    } else if (!isOpen) {
      header.classList.remove('scrolled');
    }
  }

  function init() {
    header = document.getElementById('header')!;
    btn = document.getElementById('mobile-menu-btn')!;
    menu = document.getElementById('mobile-menu')!;
    closeBtn = document.getElementById('mobile-menu-close')!;
    hasHero = !!document.querySelector('[data-hero]');

    isOpen = false;
    menu.classList.add('opacity-0', 'pointer-events-none');
    menu.classList.remove('opacity-100', 'pointer-events-auto');
    header.classList.remove('menu-open');
    btn.classList.remove('invisible');
    document.body.style.overflow = '';

    updateHeader();
  }

  window.addEventListener('scroll', updateHeader, { passive: true });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('#mobile-menu-btn')) {
      toggleMenu(!isOpen);
    } else if (target.closest('#mobile-menu-close')) {
      toggleMenu(false);
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) {
      toggleMenu(false);
    }
  });

  init();
  document.addEventListener('astro:after-swap', init);
</script>
