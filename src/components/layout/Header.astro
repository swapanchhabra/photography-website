---
import { NAV_ITEMS, SITE } from '../../utils/constants';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-[55] transition-all duration-500"
>
  <nav class="mx-auto max-w-7xl px-6 py-5 flex items-center justify-between" aria-label="Hauptnavigation">
    <!-- Logo -->
    <a href="/" class="text-xl font-bold tracking-tight text-white transition-colors duration-300" id="logo-link">
      {SITE.name}
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden lg:flex items-center gap-8" role="list">
      {NAV_ITEMS.map((item) => (
        <li>
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'relative text-sm font-medium tracking-wide uppercase transition-colors duration-300',
              'after:absolute after:bottom-[-4px] after:left-0 after:h-[1.5px] after:bg-current after:transition-all after:duration-300',
              isActive(item.href)
                ? 'text-white after:w-full'
                : 'text-white/80 hover:text-white after:w-0 hover:after:w-full',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden flex flex-col gap-1.5 p-3 z-[60] relative"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block w-6 h-[2px] bg-white transition-all duration-300 origin-center pointer-events-none" id="bar1"></span>
      <span class="block w-6 h-[2px] bg-white transition-all duration-300 pointer-events-none" id="bar2"></span>
      <span class="block w-6 h-[2px] bg-white transition-all duration-300 origin-center pointer-events-none" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    role="dialog"
    aria-label="Navigation"
    class="fixed inset-0 z-50 bg-neutral-950/98 flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-500 lg:hidden pt-[env(safe-area-inset-top)]"
  >
    <!-- Close button inside overlay -->
    <button
      id="mobile-menu-close"
      class="absolute top-8 right-6 p-3 text-white/80 hover:text-white transition-colors z-[60] pointer-events-auto"
      aria-label="Menü schließen"
    >
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <nav aria-label="Mobile Navigation">
      <ul class="flex flex-col items-center gap-8" role="list">
        {NAV_ITEMS.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class:list={[
                'text-2xl font-light tracking-widest uppercase transition-colors duration-300',
                isActive(item.href) ? 'text-accent' : 'text-white/90 hover:text-white',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('header')!;
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const closeBtn = document.getElementById('mobile-menu-close')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;
  const logoLink = document.getElementById('logo-link')!;
  let isOpen = false;

  function toggleMenu(open: boolean) {
    isOpen = open;
    btn.setAttribute('aria-expanded', String(isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Menü schließen' : 'Menü öffnen');
    if (isOpen) {
      menu.classList.remove('opacity-0', 'pointer-events-none');
      menu.classList.add('opacity-100', 'pointer-events-auto');
      btn.classList.add('invisible');
      document.body.style.overflow = 'hidden';
      // Focus close button for accessibility
      closeBtn.focus();
    } else {
      menu.classList.add('opacity-0', 'pointer-events-none');
      menu.classList.remove('opacity-100', 'pointer-events-auto');
      btn.classList.remove('invisible');
      document.body.style.overflow = '';
      btn.focus();
    }
  }

  // Scroll effect — add background after scrolling
  function updateHeader() {
    if (window.scrollY > 50) {
      header.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-sm');
      header.classList.remove('bg-transparent');
      logoLink.classList.remove('text-white');
      logoLink.classList.add('text-neutral-900');
      header.querySelectorAll<HTMLAnchorElement>('nav ul a').forEach((a) => {
        a.classList.remove('text-white/80', 'text-white');
        a.classList.add('text-neutral-600', 'hover:text-neutral-900');
      });
      [bar1, bar2, bar3].forEach((b) => {
        b.classList.remove('bg-white');
        b.classList.add('bg-neutral-900');
      });
    } else if (!isOpen) {
      header.classList.remove('bg-white/95', 'backdrop-blur-md', 'shadow-sm');
      header.classList.add('bg-transparent');
      logoLink.classList.add('text-white');
      logoLink.classList.remove('text-neutral-900');
      header.querySelectorAll<HTMLAnchorElement>('nav ul a').forEach((a) => {
        a.classList.add('text-white/80');
        a.classList.remove('text-neutral-600', 'hover:text-neutral-900');
      });
      [bar1, bar2, bar3].forEach((b) => {
        b.classList.add('bg-white');
        b.classList.remove('bg-neutral-900');
      });
    }
  }

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  btn.addEventListener('click', () => toggleMenu(!isOpen));
  closeBtn.addEventListener('click', () => toggleMenu(false));

  // Escape key closes mobile menu
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) {
      toggleMenu(false);
    }
  });
</script>
