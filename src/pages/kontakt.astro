---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ContactForm from '../components/sections/ContactForm.astro';
import { SEO } from '../data/seo';
import { SITE } from '../utils/constants';
import { breadcrumbSchema } from '../utils/schema';

const schema = breadcrumbSchema([
  { name: 'Startseite', url: SITE.url },
  { name: 'Kontakt', url: `${SITE.url}/kontakt` },
]);
---

<BaseLayout title={SEO.kontakt.title} description={SEO.kontakt.description} schema={schema}>
  <HeroSection
    title="Kontakt"
    subtitle="Schreibt mir — ich freue mich, von euch zu hören."
    image="/images/hero/home-hero.jpg"
  />

  <section class="py-20 lg:py-28 bg-white">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <!-- Form -->
        <div data-animate>
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-8">Anfrage senden</h2>
          <ContactForm />
        </div>

        <!-- Contact Info -->
        <div data-animate>
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-8">Kontaktdaten</h2>
          <div class="space-y-6">
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-widest text-neutral-400 mb-2">Adresse</h3>
              <p class="text-neutral-700">
                {SITE.name}<br />
                {SITE.address.street}<br />
                {SITE.address.postalCode} {SITE.address.city}
              </p>
            </div>
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-widest text-neutral-400 mb-2">E-Mail</h3>
              <a href={`mailto:${SITE.email}`} class="text-neutral-700 hover:text-neutral-900 transition-colors">
                {SITE.email}
              </a>
            </div>
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-widest text-neutral-400 mb-2">Telefon</h3>
              <a href={`tel:${SITE.phone.replace(/\s/g, '')}`} class="text-neutral-700 hover:text-neutral-900 transition-colors">
                {SITE.phone}
              </a>
            </div>
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-widest text-neutral-400 mb-2">Social Media</h3>
              <div class="flex gap-4">
                <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-neutral-900 transition-colors">
                  Instagram
                </a>
                <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-neutral-900 transition-colors">
                  Facebook
                </a>
              </div>
            </div>
          </div>

          <div class="mt-10 p-6 bg-neutral-50 border border-neutral-200">
            <p class="text-sm text-neutral-600 leading-relaxed">
              <strong>Antwortzeit:</strong> Ich antworte in der Regel innerhalb von 24 Stunden.
              Für dringende Anfragen erreicht ihr mich auch telefonisch.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
