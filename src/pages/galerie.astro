---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoCarousel from '../components/sections/PhotoCarousel.astro';
import GalleryGrid from '../components/sections/GalleryGrid.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import { SEO } from '../data/seo';
import { GALLERY_IMAGES } from '../data/gallery';
import { breadcrumbSchema } from '../utils/schema';
import { SITE } from '../utils/constants';

const schema = breadcrumbSchema([
  { name: 'Startseite', url: SITE.url },
  { name: 'Galerie', url: `${SITE.url}/galerie` },
]);

const carouselImages = GALLERY_IMAGES.filter((img) => img.width > img.height).slice(0, 5);
---

<BaseLayout title={SEO.galerie.title} description={SEO.galerie.description} schema={schema}>
  <!-- Hero Carousel -->
  <PhotoCarousel
    images={carouselImages}
    interval={5000}
    hero
    title="Galerie"
    subtitle="Arbeiten vom Fotograf in Ettlingen & Karlsruhe"
  />

  <section class="py-20 lg:py-28 bg-parchment">
    <div class="mx-auto max-w-7xl px-6">
      <GalleryGrid images={GALLERY_IMAGES} showFilter />
    </div>
  </section>

  <CTABanner
    title="Gefällt euch, was ihr seht?"
    subtitle="Lasst uns gemeinsam eure eigene Hochzeitsgeschichte erzählen."
    buttonLabel="Jetzt anfragen"
    buttonHref="/kontakt"
  />
</BaseLayout>
