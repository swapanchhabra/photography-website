---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Seite nicht gefunden | Pose and Say Cheese Photography" description="Die angeforderte Seite wurde nicht gefunden." noindex>
  <div class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center">
      <span class="font-serif text-8xl text-neutral-300">404</span>
      <h1 class="mt-4 font-serif text-2xl sm:text-3xl italic tracking-wide">Seite nicht gefunden</h1>
      <p class="mt-3 text-neutral-500">Die Seite, die Sie suchen, existiert leider nicht.</p>
      <a
        href="/"
        class="btn-outline mt-8"
      >
        Zurück zur Startseite
      </a>
    </div>
  </div>
</BaseLayout>
