---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import InstagramFeed from '../components/sections/InstagramFeed.astro';
import { SEO } from '../data/seo';
import { GALLERY_IMAGES } from '../data/gallery';
import { TESTIMONIALS } from '../data/testimonials';

const previewImages = GALLERY_IMAGES.slice(0, 6);
---

<BaseLayout title={SEO.home.title} description={SEO.home.description} preloadImage="/images/hero/home-hero.jpg">
  <!-- Hero -->
  <HeroSection
    title="Ihre Hochzeit. Unsere Leidenschaft."
    subtitle="Authentische und emotionale Hochzeitsfotografie in Karlsruhe und Ettlingen. Wir halten die schönsten Momente Ihres großen Tages für immer fest."
    image="/images/hero/home-hero.jpg"
    cta={{ label: 'Jetzt anfragen', href: '/kontakt' }}
    fullHeight
  />

  <!-- Highlights -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center mb-20" data-animate>
        <div class="section-divider mb-8"></div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-balance">
          Warum Pose and Say Cheese?
        </h2>
        <p class="mt-6 text-lg text-neutral-500 font-light max-w-2xl mx-auto">
          Jede Hochzeit ist einzigartig — und verdient Bilder, die das widerspiegeln.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-16" data-stagger>
        <div class="text-center" data-animate>
          <div class="w-16 h-16 mx-auto mb-6 flex items-center justify-center border border-neutral-200">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold tracking-tight">Authentische Momente</h3>
          <p class="mt-2 text-sm text-neutral-500 leading-relaxed">
            Keine gestellten Posen — ich fange die echten Emotionen und natürlichen Augenblicke Ihres Hochzeitstages ein.
          </p>
        </div>

        <div class="text-center" data-animate>
          <div class="w-16 h-16 mx-auto mb-6 flex items-center justify-center border border-neutral-200">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold tracking-tight">Professionelle Qualität</h3>
          <p class="mt-2 text-sm text-neutral-500 leading-relaxed">
            Jedes einzelne Bild wird liebevoll bearbeitet. Sie erhalten ausschließlich hochwertige, druckreife Fotos.
          </p>
        </div>

        <div class="text-center" data-animate>
          <div class="w-16 h-16 mx-auto mb-6 flex items-center justify-center border border-neutral-200">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold tracking-tight">Persönliche Betreuung</h3>
          <p class="mt-2 text-sm text-neutral-500 leading-relaxed">
            Von der ersten Anfrage bis zur Bildübergabe — ich bin persönlich für Sie da und gehe auf Ihre Wünsche ein.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Preview -->
  <section class="py-20 lg:py-28 bg-neutral-50">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center mb-16" data-animate>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight">
          Ein Blick in unsere Arbeit
        </h2>
      </div>

      <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
        {previewImages.map((img) => (
          <div class="break-inside-avoid group overflow-hidden" data-animate>
            <div class="relative overflow-hidden">
              <img
                src={img.src}
                alt={img.alt}
                width={img.width}
                height={img.height}
                loading="lazy"
                decoding="async"
                class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
              />
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-12" data-animate>
        <a
          href="/galerie"
          class="inline-block px-8 py-4 border border-neutral-900 text-neutral-900 text-sm font-semibold uppercase tracking-widest hover:bg-neutral-900 hover:text-white transition-all duration-300"
        >
          Alle Fotos entdecken
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-24 lg:py-32 bg-warm-cream">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center mb-6" data-animate>
        <div class="section-divider mb-8"></div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight">
          Was unsere Paare sagen
        </h2>
      </div>

      <!-- Featured testimonial -->
      <div class="max-w-3xl mx-auto text-center mb-16 mt-12" data-animate>
        <span class="font-serif text-6xl lg:text-7xl text-accent leading-none" aria-hidden="true">&ldquo;</span>
        <blockquote class="font-serif text-xl sm:text-2xl lg:text-3xl text-neutral-800 leading-relaxed italic -mt-6">
          {TESTIMONIALS[0].text}
        </blockquote>
        <div class="mt-8 flex items-center justify-center gap-4">
          <div class="w-14 h-14 rounded-full overflow-hidden bg-neutral-200">
            <img src={TESTIMONIALS[0].image} alt={TESTIMONIALS[0].name} width="56" height="56" loading="lazy" class="w-full h-full object-cover" />
          </div>
          <cite class="text-sm font-semibold not-italic tracking-wide">{TESTIMONIALS[0].name}</cite>
        </div>
      </div>

      <!-- Other testimonials -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 max-w-4xl mx-auto" data-stagger>
        {TESTIMONIALS.slice(1).map((t) => (
          <div class="text-center p-8 bg-white/70 animate-fade-in-up" data-animate>
            <blockquote class="font-serif text-base text-neutral-600 leading-relaxed italic">
              &ldquo;{t.text}&rdquo;
            </blockquote>
            <div class="mt-6 flex items-center justify-center gap-3">
              <div class="w-10 h-10 rounded-full overflow-hidden bg-neutral-200">
                <img src={t.image} alt={t.name} width="40" height="40" loading="lazy" class="w-full h-full object-cover" />
              </div>
              <cite class="text-sm font-semibold not-italic">{t.name}</cite>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Instagram -->
  <InstagramFeed />

  <!-- CTA -->
  <CTABanner
    title="Bereit für Ihren großen Tag?"
    subtitle="Lassen Sie uns gemeinsam Ihre Hochzeitsmomente festhalten."
    buttonLabel="Jetzt anfragen"
    buttonHref="/kontakt"
  />
</BaseLayout>
