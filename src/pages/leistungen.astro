---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import { SEO } from '../data/seo';
import { breadcrumbSchema } from '../utils/schema';
import { SITE } from '../utils/constants';

const schema = breadcrumbSchema([
  { name: 'Startseite', url: SITE.url },
  { name: 'Leistungen', url: `${SITE.url}/leistungen` },
]);

const services = [
  {
    title: 'Getting Ready',
    description: 'Die aufregenden Vorbereitungen — vom Styling bis zum letzten Handgriff. Ich halte die Vorfreude, die Emotionen und die kleinen Details fest, die den Anfang eures großen Tages ausmachen.',
  },
  {
    title: 'Trauung',
    description: 'Ob standesamtlich, kirchlich oder freie Trauung — ich dokumentiere die Zeremonie diskret und einfühlsam. Jeder Blick, jede Träne, jedes Lächeln wird festgehalten.',
  },
  {
    title: 'Brautpaarshooting',
    description: 'Nach der Trauung nehmen wir uns Zeit für entspannte Paarfotos. An eurem Wunschort entstehen natürliche, romantische Bilder voller Emotionen.',
  },
  {
    title: 'Gruppenfotos',
    description: 'Schnell, unkompliziert und mit guter Laune — professionelle Gruppenfotos mit Familie und Freunden, die Spaß machen.',
  },
  {
    title: 'Feier & Party',
    description: 'Der erste Tanz, die Reden, das Lachen — ich bin bis zum Schluss dabei und fange die ausgelassene Stimmung eurer Feier ein.',
  },
  {
    title: 'Hochzeitsalbum',
    description: 'Auf Wunsch gestalte ich ein hochwertiges Hochzeitsalbum, das eure schönsten Momente in einem edlen Buch vereint — ein Erbstück für Generationen.',
  },
];
---

<BaseLayout title={SEO.leistungen.title} description={SEO.leistungen.description} schema={schema}>
  <HeroSection
    title="Leistungen"
    subtitle="Professionelle Hochzeitsfotografie — von den Vorbereitungen bis zur letzten Party."
    image="/images/hero/services-hero.jpg"
  />

  <!-- Approach -->
  <section class="py-20 lg:py-28 bg-parchment">
    <div class="mx-auto max-w-3xl px-6 text-center" data-animate>
      <h2 class="text-3xl sm:text-4xl font-serif italic tracking-wide text-neutral-700">Mein Ansatz</h2>
      <p class="mt-6 text-neutral-500 leading-relaxed">
        Ich glaube an authentische Fotografie. Keine erzwungenen Posen, keine übertriebene Inszenierung.
        Stattdessen begleite ich euch unauffällig durch den Tag und fange die echten Momente ein —
        die Freudentränen, das herzliche Lachen, die stillen Blicke. So entstehen Bilder,
        die eure Geschichte ehrlich erzählen.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20 lg:py-28 bg-neutral-50">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center mb-16" data-animate>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-serif italic tracking-wide text-neutral-700">
          Was ich anbiete
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <div class="bg-parchment p-8 lg:p-10 border border-neutral-200 transition-all duration-300 hover:border-neutral-400" data-animate>
            <h3 class="text-xl font-serif italic tracking-wide text-neutral-700">{service.title}</h3>
            <p class="mt-3 text-sm text-neutral-500 leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-20 lg:py-28 bg-parchment">
    <div class="mx-auto max-w-5xl px-6">
      <div class="text-center mb-16" data-animate>
        <h2 class="text-3xl sm:text-4xl font-serif italic tracking-wide text-neutral-700">So läuft es ab</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {[
          { step: '01', title: 'Anfrage', desc: 'Schreibt mir und erzählt von eurer Hochzeit.' },
          { step: '02', title: 'Kennenlernen', desc: 'Wir treffen uns persönlich und besprechen eure Wünsche.' },
          { step: '03', title: 'Der große Tag', desc: 'Ich begleite euch und halte alle Momente fest.' },
          { step: '04', title: 'Eure Bilder', desc: 'Nach 6–8 Wochen erhaltet ihr eure fertige Galerie.' },
        ].map((item) => (
          <div class="text-center" data-animate>
            <span class="text-4xl font-bold text-accent">{item.step}</span>
            <h3 class="mt-3 text-lg font-serif italic tracking-wide text-neutral-700">{item.title}</h3>
            <p class="mt-2 text-sm text-neutral-500">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Business Portraits Teaser -->
  <section class="py-20 lg:py-28 bg-neutral-50">
    <div class="mx-auto max-w-4xl px-6 text-center" data-animate>
      <div class="section-divider mb-8"></div>
      <h2 class="font-serif text-3xl sm:text-4xl italic tracking-wide">Business Portraits</h2>
      <p class="mt-6 text-neutral-500 leading-relaxed">
        Neben Hochzeiten biete ich auch professionelle Business-Porträts an — im Studio in Ettlingen
        oder outdoor. Ob Bewerbungsfoto, LinkedIn-Profil oder Teamfotos für eure Firma.
      </p>
      <div class="mt-10">
        <a
          href="/business-portraits"
          class="inline-block px-10 py-4 border border-neutral-400 text-neutral-600 text-xs tracking-[0.25em] uppercase hover:border-neutral-700 hover:text-neutral-700 transition-all duration-300"
        >
          Mehr erfahren
        </a>
      </div>
    </div>
  </section>

  <CTABanner
    title="Klingt gut?"
    subtitle="Lasst uns über eure Hochzeit sprechen."
    buttonLabel="Zu den Preisen"
    buttonHref="/preise"
  />
</BaseLayout>
